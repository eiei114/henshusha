{
  "name": "henshusha-monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "Agent-native video editing workspace for Claude Code, Codex, and Pi.",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "node scripts/build.mjs",
    "check": "node scripts/typecheck.mjs",
    "dev": "node scripts/typecheck.mjs",
    "dev:doctor": "node scripts/typecheck.mjs",
    "dev:fixture": "node scripts/create-fixture.mjs",
    "dev:sample-media": "node scripts/create-sample-media.mjs",
    "test:henshusha": "node scripts/build.mjs && node scripts/verify-henshusha-cli-entry.mjs",
    "test:timeline-schema": "node scripts/verify-timeline-schema.mjs",
    "dev:verify-render": "node scripts/verify-render.mjs",
    "lint": "node scripts/typecheck.mjs",
    "test": "node scripts/typecheck.mjs",
    "typecheck": "node scripts/typecheck.mjs",
    "build:bun": "bun scripts/build.mjs",
    "dev:bun": "bun scripts/typecheck.mjs",
    "typecheck:bun": "bun scripts/typecheck.mjs"
  },
  "keywords": [
    "video",
    "remotion",
    "ffmpeg",
    "whisper",
    "agents",
    "claude-code",
    "codex",
    "pi"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eiei114/henshusha.git"
  },
  "bugs": {
    "url": "https://github.com/eiei114/henshusha/issues"
  },
  "homepage": "https://github.com/eiei114/henshusha#readme",
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20",
    "bun": ">=1.3.0"
  }
}
